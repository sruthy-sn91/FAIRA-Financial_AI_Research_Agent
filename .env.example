# ── LLM ──────────────────────────────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Local Ollama model (no key needed — must have Ollama installed)
OLLAMA_MODEL=llama3.1:8b

# Set to "groq" for production, "ollama" for local dev
LLM_PROVIDER=ollama

# ── Data APIs ─────────────────────────────────────────────────────────
# Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Get free key at: https://e2b.dev
E2B_API_KEY=your_e2b_api_key_here

# ── Application ───────────────────────────────────────────────────────
# Path where ChromaDB stores its vector index
CHROMA_PATH=./data/chroma

# Path where downloaded SEC filings are saved
FILINGS_PATH=./data/filings

# FastAPI server
API_HOST=0.0.0.0
API_PORT=8000

# MLflow tracking
MLFLOW_TRACKING_URI=./mlflow_runs
