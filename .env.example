# ── LLM ──────────────────────────────────────────────────────────────────────
# Choose one provider: ollama (local) or groq (cloud)
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b

# Required when LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# ── Data APIs ─────────────────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# E2B sandboxed code execution — https://e2b.dev
E2B_API_KEY=your_e2b_api_key_here

# ── Application ───────────────────────────────────────────────────────────────
# Paths below are for local development; Docker overrides them via environment:
CHROMA_PATH=./data/chroma
FILINGS_PATH=./data/filings
API_HOST=0.0.0.0
API_PORT=8000

# MLflow tracking URI — use HTTP address when running inside Docker:
#   Local dev : ./mlflow_runs
#   Docker    : http://mlflow:5000  (set automatically by docker-compose)
MLFLOW_TRACKING_URI=./mlflow_runs
